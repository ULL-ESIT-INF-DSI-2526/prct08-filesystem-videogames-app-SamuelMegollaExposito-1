{
  "compilerOptions": {
    "rootDir": ".", 
    "outDir": "./dist",
    "module": "node16",
    "moduleResolution": "node16",
    "target": "es2024",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "declaration": true,
    "types": ["node"]
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.ts" 
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}